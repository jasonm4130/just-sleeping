---
import Layout from "../layouts/Layout.astro";
---
<Layout title="404 — also sleeping">
  <main class="u-container lost">
    <section class="card u-grain">
      <div class="tape"></div>
      <div class="num">404</div>
      <h1>this one's<br />sleeping too</h1>
      <p class="lead">there's nothing here. it's resting.<br />the page you wanted is having a lie-down.</p>
      <a class="back" href="/">← back to the others</a>
      <p class="fine">do not wake the URL. it has done nothing wrong.</p>
    </section>
  </main>
</Layout>

<style>
  .lost { min-height: 80vh; display: flex; align-items: center; justify-content: center; }
  .card { position: relative; background: var(--color-card); padding: 3.4rem 3rem; box-shadow: 0 26px 60px -20px rgba(0,0,0,.65); transform: rotate(-0.6deg); text-align: center; max-width: 480px; }
  .tape { position: absolute; top: -14px; left: 50%; width: 130px; height: 32px; margin-left: -65px; background: var(--tape); mix-blend-mode: multiply; box-shadow: 0 1px 6px rgba(0,0,0,.18); transform: rotate(-2deg); }
  .num { font-family: var(--font-display); font-size: clamp(56px, 16vw, 96px); line-height: .9; color: var(--color-accent); text-shadow: 2px 2px 0 rgba(0,0,0,.08); }
  h1 { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; font-size: clamp(24px, 6vw, 38px); line-height: .95; letter-spacing: -.5px; margin: 12px 0 0; color: var(--color-ink); }
  .lead { font-size: 15px; line-height: 1.7; margin: 22px 0 0; opacity: .85; }
  .back { display: inline-block; margin-top: 26px; font-family: var(--font-hand); font-weight: 700; font-size: 26px; color: var(--color-accent); text-decoration: none; transform: rotate(-1.5deg); }
  .back:hover { text-decoration: underline; }
  .fine { font-size: 10px; letter-spacing: 1px; opacity: .5; margin: 26px 0 0; }
</style>
